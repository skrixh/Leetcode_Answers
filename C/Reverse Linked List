struct ListNode* reverseList(struct ListNode* head) {
    if(head==NULL){
        return head;
    }
    struct ListNode* prev = NULL;
    struct ListNode* curr = head;
    struct ListNode* next = head->next;
    while(curr!=NULL){
        next = curr->next;
        curr->next = prev;
        prev = curr;
        curr = next;
    }
    return prev;
}
